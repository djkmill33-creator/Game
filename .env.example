# Option build-time : tous les frontends construits avec cette URL partagent le même record.
# VITE_RECORD_API_URL=https://api.example.com/api/record

# Option serveur : emplacement persistant du fichier record côté API Node.
# RECORD_FILE=/var/lib/mon-jeu-plus/record.json

# Option runtime serveur : force record-config.js à pointer vers l'API centrale.
# CENTRAL_RECORD_API_URL=https://api.example.com/api/record
